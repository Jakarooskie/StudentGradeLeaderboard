 * Description: 
 *   This program creates a leaderboard for students based on their grades.
 *   Users can input up to 100 students, including their names and grades.
 *   The leaderboard can be displayed either from Highest to Lowest or Lowest to Highest.
 */

#include <stdio.h>
#include <string.h>
#include <stdlib.h>

// Max number of students allowed
#define MAX_STUDENTS 100

// Player struct to store each student's name and grade
typedef struct { 
    char name[20];  // Student's name (max 19 characters + null terminator)
    int grade;      // Student's grade (0 - 100)
} Player;

/*
 * leaderboardSort - Sorts the players array using bubble sort
 * Parameters:
 *   players[]  - Array of Player structs to sort
 *   n          - Number of students in the array
 *   descending - 1 = Highest to Lowest, 0 = Lowest to Highest
 */
void leaderboardSort(Player players[], int n, int descending) {
    for (int i = 0; i < n - 1; i++) {          // Outer loop: each pass guarantees one more element is in place
        for (int j = 0; j < n - i - 1; j++) {  // Inner loop: compare adjacent elements, shrinks each pass
            
            // Ternary operator: picks direction of leaderboard based off of value of a.
            // descending=1 → swap if left grade is LESS than right (push higher grades left)
            // descending=0 → swap if left grade is GREATER than right (push lower grades left)
            int shouldSwap = descending
                ? players[j].grade < players[j + 1].grade
                : players[j].grade > players[j + 1].grade;

            if (shouldSwap) {
                // Swap the two adjacent players using a temporary variable
                Player temp = players[j];
                players[j] = players[j + 1];
                players[j + 1] = temp;
            }
        }
    }
}

int main() { 
    int n; // Number of students to input

    // Ask user for number of students
    printf("How many students? ");
    scanf("%d", &n);

    // Validate: reject input over the max limit
    if (n > MAX_STUDENTS) {
        printf("TOO MANY STUDENTS! Max is %d\n", MAX_STUDENTS);
        exit(1);
    }

    // Declare array of Player structs to hold all student data
    Player players[MAX_STUDENTS];

    // --------------------------
    // Input student data
    // --------------------------
    for (int i = 0; i < n; i++) {
        printf("Student %d's name is: ", i + 1);
        while (getchar() != '\n');                              // Flush input buffer so fgets works correctly
        fgets(players[i].name, 20, stdin);                     // Read full name (supports spaces)
        players[i].name[strcspn(players[i].name, "\n")] = 0;  // Delete trailing newline left by fgets

        // Keep asking until a valid grade (0-100) is entered
        do {
            printf("Student %d's grade: ", i + 1);
            scanf("%d", &players[i].grade);
            if (players[i].grade < 0 || players[i].grade > 100) {
                printf("INVALID! Enter a grade between 0 and 100\n");
            }
        } while (players[i].grade < 0 || players[i].grade > 100);
    }

    // ---------------------------------------
    // Ask user how to display the leaderboard
    // ---------------------------------------
    int a;
    printf("How do you want the Leaderboard Displayed?\n");
    printf("1 = Highest to Lowest, 0 = Lowest to Highest: ");
    scanf("%d", &a);

    // Call sort function with user's choice
    // If input is invalid, default to descending (1)
    if (a == 1 || a == 0) {
        leaderboardSort(players, n, a);  // Pass a directly — 1 or 0 becomes the descending parameter
    } else {
        printf("Invalid choice, displaying Highest to Lowest by default\n");
        leaderboardSort(players, n, 1);  // Hardcode 1 since user input can't be trusted
    }

    // ---------------------------
    // Print the final leaderboard
    // ---------------------------
    printf("---Leaderboard---\n");
    for (int i = 0; i < n; i++) {
        printf("%d - %s - %d\n", i + 1, players[i].name, players[i].grade); // Rank - Name - Grade
    }

    return 0;
}
